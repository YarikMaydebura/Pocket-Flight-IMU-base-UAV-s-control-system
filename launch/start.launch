<launch>
    <!-- Simulation mode argument (default: true for Gazebo) -->
    <arg name="sim" default="true" />

    <!-- Load IMU control parameters -->
    <rosparam file="$(find pocketflight_imu)/config/imu_control.yaml" command="load" />

    <!-- Start IMU publisher node (smartphone sensor bridge) -->
    <node pkg="pocketflight_imu" type="imu_publisher.py" name="imu_publisher" output="screen" />

    <!-- Start controller node (IMU-based drone control with PID) -->
    <node pkg="pocketflight_imu" type="controller.py" name="controller" output="screen" />

    <!-- Use simulation time when running in Gazebo -->
    <param name="use_sim_time" value="$(arg sim)" />
</launch>
